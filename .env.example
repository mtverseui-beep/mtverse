# mtverse launch env template
# Copy to .env.local and fill values. Never commit real secrets.

# Site
NEXT_PUBLIC_SITE_URL=https://www.mtverse.dev
NEXTAUTH_URL=https://www.mtverse.dev
AUTH_URL=https://www.mtverse.dev
NEXT_PUBLIC_ENABLE_MULTILINGUAL_HREFLANG=false

# Social & contact links (used site-wide in footer, contact page, structured data)
NEXT_PUBLIC_SOCIAL_EMAIL=hello@mtverse.dev
NEXT_PUBLIC_SOCIAL_GITHUB=https://github.com/mtverse
NEXT_PUBLIC_SOCIAL_TWITTER=https://x.com/mtverse

# Search engine ownership verification (public meta-tag tokens)
YANDEX_SITE_VERIFICATION=
NAVER_SITE_VERIFICATION=

# Cloudflare Web Analytics
# Add the site token from Cloudflare Analytics > Web Analytics to load the beacon.
NEXT_PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN=

# Admin access
ADMIN_EMAIL=
# 64-character scrypt hex hash used by src/lib/admin-auth.ts.
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=

# Customer auth
CUSTOMER_SESSION_SECRET=
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Paddle checkout
# Use sandbox credentials for local Paddle testing; set production with matching live credentials at launch.
PAYMENT_PROVIDER=paddle
NEXT_PUBLIC_PADDLE_ENVIRONMENT=sandbox
PADDLE_CLIENT_TOKEN=
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
# Shared normal + pro one-time prices; kitSlug identifies the selected template.
PADDLE_NEXT_PRICE_ID=
PADDLE_PRO_PRICE_ID=
PADDLE_OOSTER_PRO_PRICE_ID=
PADDLE_FREE_UNLOCK_PRICE_ID=
PADDLE_ALL_PAID_PRICE_ID=

# Cloudflare R2 storage
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
# Must be a separate private bucket with no r2.dev or custom public domain.
CLOUDFLARE_R2_PACKAGE_BUCKET=
CLOUDFLARE_R2_PUBLIC_URL=
CLOUDFLARE_R2_PACKAGE_PREFIX=packages
CLOUDFLARE_R2_TEMPLATE_PREVIEW_PREFIX=templates/dashboard-previews
CLOUDFLARE_R2_TEMPLATE_PACKAGE_PREFIX=templates/dashboards

# Shared production storage/rate limiting
HEALTHCHECK_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Newsletter and feedback
EMAILJS_SERVICE_ID=
EMAILJS_FEEDBACK_TEMPLATE_ID=
EMAILJS_PASSWORD_RESET_TEMPLATE_ID=
EMAILJS_NEWSLETTER_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=

# Google AdSense
# NEXT_PUBLIC_GOOGLE_ADSENSE_CLIENT accepts ca-pub-0000000000000000 or pub-0000000000000000.
# Set NEXT_PUBLIC_GOOGLE_ADSENSE_ENABLED=true only when you intentionally want the AdSense script to load.
NEXT_PUBLIC_GOOGLE_ADSENSE_ENABLED=false
NEXT_PUBLIC_GOOGLE_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=
NEXT_PUBLIC_ADSENSE_SLOT_INLINE=
NEXT_PUBLIC_ADSENSE_SLOT_FOOTER=
